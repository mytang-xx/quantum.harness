&CONTROL
  calculation = 'scf'
  restart_mode = 'from_scratch'
  prefix = 'qmc_solid'
  pseudo_dir = './pseudo'
  outdir = './qe_tmp'
  tstress = .true.
  tprnfor = .true.
  verbosity = 'high'
  wf_collect = .true.
/
&SYSTEM
  ibrav = 0
  nat = 8
  ntyp = 1
  input_dft = 'PBE'
  ecutwfc = 100
  ecutrho = 400
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.0036749322
/
&ELECTRONS
  conv_thr = 1.0d-10
  electron_maxstep = 100
  mixing_beta = 0.3
/
