.DS_Store
# Only Project.toml is committed (the dependency contract). Manifest.toml is
# platform/version-pinned (see `julia_version` field) and would break
# cross-machine syncing — each environment resolves its own Manifest from
# Project.toml on first instantiate.
julia-env/Manifest.toml
julia-env/.CondaPkg/
.julia/
knowledge-base/literature/**/.raw/
knowledge-base/literature/**/.figures/

