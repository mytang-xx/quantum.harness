{
  "_comment": "EDITORIAL TEMPLATE — replace every <PLACEHOLDER> with your reproduction's content. Every prose field is sourced from the evidence pack; populate `sourced_by` with file:line references. Inline markup supported in any prose field: [[glossary-key|display]], *italic*, _X / _{XX} (subscript), ^X / ^{XX} (superscript), Greek words (alpha, chi, sigma, ...) → Unicode, <=/>=/!=/+/-/\\approx → ≤≥≠±≈. The renderer applies these automatically; write plain ASCII.",

  "headline": {
    "text": "<ONE SENTENCE: claim + framing. Use [[key|symbol]] for any project-specific symbol so it gets a glossary tooltip. Avoid project jargon without a tooltip.>",
    "sourced_by": ["protocol.toml#L<line>", "verify_<artifact>_<date>.md#L<line>"]
  },

  "claims": [
    {
      "id": "<protocol claim id>",
      "display_label": "<short human label, ≤ 20 chars; no jargon without expansion>",
      "popover": "<ONE SENTENCE: what was checked + the result. Cite numbers when available.>",
      "sourced_by": ["protocol.toml#L<line>", "verify_<artifact>_<date>.md#L<line>"]
    }
  ],

  "deviations": [
    {
      "id": "<protocol deviation id>",
      "display_label": "<short human label>",
      "popover": "<ONE SENTENCE: what differs + why it matters>",
      "discrepancy_paragraph": "<≤ 2 SENTENCES for the discrepancy panel. Quantify impact when verify supports a number (e.g., '5-20× overshoot in 13 of 28 cells').>",
      "sourced_by": ["protocol.toml#L<line>"]
    }
  ],

  "checks": [
    {
      "_comment": "Only for [[checks]] tagged audience=true. Mechanical checks such as cover, exists, agree, and fresh should stay internal unless the protocol author intentionally exposes them.",
      "id": "<protocol check id>",
      "display_label": "<short human label, e.g. 'symmetry sector', 'limit-check L=8'>",
      "popover": "<ONE SENTENCE: what was checked + outcome>",
      "sourced_by": ["protocol.toml#L<line>", "verify_<artifact>_<date>.md#L<line>"]
    }
  ],

  "pending": [
    {
      "id": "<protocol pending id>",
      "display_label": "<short human label>",
      "popover": "<ONE SENTENCE: what obligation remains>",
      "sourced_by": ["protocol.toml#L<line>"]
    }
  ],

  "figures": [
    {
      "label": "<protocol figure id; one entry per [[figures]] in protocol.toml>",
      "caption_paper": "<ONE SENTENCE describing what the paper figure shows. Spell out symbols on first use OR wrap in [[key|symbol]].>",
      "caption_ours": "<ONE SENTENCE describing what your reproduction shows + how it compares.>",
      "paper_context": "<(Sec.X / Fig.Y caption.) ONE SENTENCE quoting or paraphrasing the paper's own framing of WHY this figure exists. Renderer prepends the 'From the paper' label automatically — do not repeat it. Open with the paper-section reference in parens, then the substance.>",
      "sourced_by": ["paper-notes.md#L<line>"]
    }
  ],

  "glossary": [
    {
      "key": "<short alphanumeric key referenced by [[key|...]] markup>",
      "symbol": "<the symbol as displayed, e.g. 'c_L(h)'>",
      "name": "<full human name, e.g. 'Subleading SRE term c_L(h)'>",
      "body": "<ONE SENTENCE plain-language definition. Assume reader knows general physics but not your project.>",
      "formula": "<optional: closed-form definition, e.g. 'c_L = 2 M_2(L/2) − M_2(L)'>",
      "sourced_by": ["paper-notes.md#L<line>"]
    }
  ],

  "discrepancy_headline": "<ONE SENTENCE for the discrepancy panel <h3>; renders in warm-warn color. Names the most impactful deviation in plain language.>",

  "gaps": []
}
