#!/usr/bin/env bash
set -euo pipefail

input="${1:?Usage: render <file.md> [--title <title>]}"
title="${3:-$(basename "${input%.*}")}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATE="$SCRIPT_DIR/../templates/render-template.html"
output="${input%.*}.html"

if command -v quarto >/dev/null 2>&1; then
  quarto render "$input" --to html --output "$(basename "$output")" --self-contained 2>/dev/null
else
  content=$(cat "$input")
  sed -e "s|{{TITLE}}|$title|g" \
      -e "/{{CONTENT}}/{
        r /dev/stdin
        d
      }" "$TEMPLATE" <<< "$content" > "$output"
fi

open "$output" 2>/dev/null || xdg-open "$output" 2>/dev/null || echo "Open: $output"
