#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
bin="$repo_root/tools/flow/target/release/harness-flow"

if [[ -x "$bin" ]]; then
  exec "$bin" "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --manifest-path "$repo_root/tools/flow/Cargo.toml" -- "$@"
fi

echo "harness-flow is not built and cargo is not installed. Run: make setup" >&2
exit 127
