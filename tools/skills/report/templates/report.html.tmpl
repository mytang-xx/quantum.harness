<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>__PAGE_TITLE__</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400;1,8..60,500&family=Inter:ital,wght@0,400;0,450;0,500;0,600;1,400;1,500&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --parchment: #f5f4ed; --ivory: #faf9f5; --sand: #e8e6dc;
    --border-cream: #f0eee6; --border-warm: #e8e6dc; --ring-warm: #d1cfc5;
    --near-black: #141413; --charcoal: #4d4c48; --olive: #5e5d59;
    --stone: #87867f; --silver: #b0aea5;
    --terracotta: #c96442; --coral: #d97757;
    --paper-band: rgba(94, 93, 89, 0.10);
    --serif: 'Source Serif 4', 'Tiempos Headline', Georgia, serif;
    --sans: 'Inter', system-ui, -apple-system, Arial, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', Menlo, ui-monospace, monospace;
  }
  *, *::before, *::after { box-sizing: border-box; }
  html, body { background: var(--parchment); margin: 0; padding: 0; overflow-x: hidden; }
  body { font-family: var(--sans); color: var(--near-black); -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  ::selection { background: var(--terracotta); color: var(--ivory); }

  .topbar { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 24px;
    max-width: 1240px; margin: 0 auto; padding: 22px 40px; border-bottom: 1px solid var(--border-warm); }
  .topbar .id { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.06em; color: var(--terracotta); border: 1px solid var(--terracotta); padding: 4px 10px; border-radius: 4px; display: inline-block; margin-right: 14px; }
  .topbar .paper { font-family: var(--sans); font-size: 13px; color: var(--olive); }
  .topbar .paper b { color: var(--near-black); font-weight: 500; }
  .topbar .paper a { color: var(--terracotta); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 150ms ease; }
  .topbar .paper a:hover { border-bottom-color: var(--terracotta); }
  .topbar .meta { font-family: var(--mono); font-size: 11px; color: var(--stone); text-align: right; line-height: 1.6; }

  .hero { max-width: 1240px; margin: 0 auto; padding: 36px 40px 28px; }
  .claim-line { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 26px; }
  .claim { font-family: var(--serif); font-weight: 500; font-size: 32px; line-height: 1.18;
    color: var(--near-black); letter-spacing: -0.012em; text-wrap: balance; margin: 0; }
  .claim em { font-style: italic; color: var(--terracotta); font-weight: 500; }
  .claim .sym { font-family: var(--serif); font-style: italic; border-bottom: 1px dotted var(--stone); cursor: help; transition: border-color 150ms ease; }
  .claim .sym:hover { border-bottom-color: var(--terracotta); border-bottom-style: solid; }
  .claim-tag { font-family: var(--sans); font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terracotta); white-space: nowrap; flex-shrink: 0; padding-top: 6px; }

  /* Verdict band — answers "did this reproduce?" in the first second.
     Subsumes the older "deviation banner" by surfacing both the overall
     verdict and the key-deviation summary in a single visually-loud strip. */
  .verdict {
    display: flex; align-items: center; gap: 16px;
    padding: 14px 18px;
    border-radius: 14px;
    margin: 0 0 24px;
    font-family: var(--sans);
    line-height: 1.5;
  }
  .verdict-icon { font-size: 24px; line-height: 1; flex-shrink: 0; }
  .verdict-text { flex: 1; }
  .verdict-label {
    font-weight: 600; letter-spacing: 0.10em; text-transform: uppercase;
    font-size: 11px; margin-right: 10px;
  }
  .verdict-detail { font-size: 13.5px; color: var(--charcoal); }
  .verdict a { text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 1px; }

  /* Status palette: match (calm olive), partial (warm coral), fail (alarm
     terracotta), unknown (mute stone). Background tints + border tints follow. */
  .verdict-match    { background: rgba(94,93,89,0.04);   border: 1px solid rgba(94,93,89,0.28); }
  .verdict-match    .verdict-icon, .verdict-match    .verdict-label, .verdict-match    a { color: var(--olive); }
  .verdict-partial  { background: rgba(217,119,87,0.06); border: 1px solid rgba(217,119,87,0.40); }
  .verdict-partial  .verdict-icon, .verdict-partial  .verdict-label, .verdict-partial  a { color: var(--coral); }
  .verdict-fail     { background: rgba(201,100,66,0.07); border: 1px solid rgba(201,100,66,0.45); }
  .verdict-fail     .verdict-icon, .verdict-fail     .verdict-label, .verdict-fail     a { color: var(--terracotta); }
  .verdict-unknown  { background: rgba(135,134,127,0.04); border: 1px solid rgba(135,134,127,0.30); }
  .verdict-unknown  .verdict-icon, .verdict-unknown  .verdict-label, .verdict-unknown  a { color: var(--stone); }

  /* ===== SIDE-BY-SIDE ===== */
  .duo {
    display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
  }
  .panel-card {
    background: var(--ivory);
    border: 1px solid var(--border-cream);
    border-radius: 24px;
    padding: 24px 26px 18px;
    box-shadow: 0 0 0 1px var(--border-cream), 0 6px 32px rgba(20,20,19,0.05);
    position: relative;
    display: flex; flex-direction: column;
  }
  .panel-head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 14px;
    font-family: var(--sans);
  }
  .panel-head .label {
    font-size: 10px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--terracotta);
  }
  .panel-head .label.ref { color: var(--olive); }
  .panel-head .source { font-family: var(--mono); font-size: 10.5px; color: var(--stone); }
  .panel-title {
    font-family: var(--serif); font-weight: 500; font-size: 16px; line-height: 1.30;
    color: var(--near-black); margin: 0 0 14px;
    letter-spacing: -0.005em;
  }

  .paper-img-wrap {
    background: #fff; border: 1px solid var(--border-cream); border-radius: 12px;
    padding: 18px 22px; flex: 1;
    display: flex; align-items: center; justify-content: center;
    min-height: 360px;
  }
  .paper-img-wrap img {
    max-width: 100%; height: auto; display: block;
    image-rendering: -webkit-optimize-contrast;
  }
  .paper-cap {
    margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--border-cream);
    font-family: var(--sans); font-size: 12.5px; line-height: 1.6; color: var(--olive);
  }
  .paper-cap b { color: var(--near-black); font-weight: 500; }
  .paper-cap:empty { display: none; }

  /* Paper-context: paper-faithful explanation of WHY the figure exists, sourced
     from the paper's own caption / surrounding paragraph (not editorialized). */
  .paper-context {
    margin-top: 10px;
    font-family: var(--sans); font-size: 12px; line-height: 1.55;
    color: var(--olive); font-style: italic;
  }
  .paper-context-label {
    font-style: normal; font-weight: 500; letter-spacing: 0.06em;
    text-transform: uppercase; font-size: 9.5px;
    color: var(--terracotta); margin-right: 6px;
  }

  /* Reproduction plot */
  .plot-area { position: relative; min-height: 360px; flex: 1; }
  svg.plot { width: 100%; height: 360px; user-select: none; display: block; }
  svg.plot .grid { stroke: var(--border-warm); stroke-dasharray: 1 4; stroke-width: 0.5; }
  svg.plot .axis { stroke: var(--stone); stroke-width: 0.8; }
  svg.plot .axis-label { fill: var(--olive); font-size: 12px; font-family: var(--sans); font-weight: 450; }
  svg.plot .tick { fill: var(--stone); font-size: 10.5px; font-family: var(--mono); }
  svg.plot .curve { fill: none; stroke-width: 1.7; transition: opacity 220ms ease, stroke-width 220ms ease; }
  svg.plot .curve.dim { opacity: 0.18; }
  svg.plot .curve.focus { stroke-width: 2.6; }
  svg.plot .pt { transition: opacity 200ms ease, r 140ms ease; cursor: pointer; }
  svg.plot .pt.dim { opacity: 0.18; }
  svg.plot .errbar { stroke-width: 1.2; opacity: 0.50; transition: opacity 220ms ease; }
  svg.plot .errbar.dim { opacity: 0.10; }
  svg.plot .draw { stroke-dasharray: 2400; stroke-dashoffset: 2400; animation: draw 1100ms cubic-bezier(0.32, 0.72, 0, 1) forwards; }
  svg.plot .zero { stroke: var(--silver); stroke-width: 0.6; opacity: 0.5; }
  svg.plot .hcline { stroke: var(--terracotta); stroke-width: 0.6; stroke-dasharray: 4 4; opacity: 0.55; }
  svg.plot .hclabel { fill: var(--terracotta); font-family: var(--mono); font-size: 11px; opacity: 0.85; }
  svg.plot .paper-window { fill: var(--paper-band); stroke: none; opacity: 0; transition: opacity 320ms ease; pointer-events: none; }
  svg.plot .paper-window.on { opacity: 1; }
  svg.plot .paper-window-label { fill: var(--olive); font-family: var(--sans); font-size: 10.5px; font-style: italic; opacity: 0; transition: opacity 320ms ease; }
  svg.plot .paper-window-label.on { opacity: 0.85; }
  @keyframes draw { to { stroke-dashoffset: 0; } }

  .ours-controls {
    position: absolute; top: 22px; right: 26px; display: flex; gap: 6px;
  }
  .toggle {
    font-family: var(--sans); font-size: 11px; font-weight: 500;
    background: var(--parchment); border: 1px solid var(--border-warm);
    color: var(--charcoal); border-radius: 999px; padding: 4px 10px;
    cursor: pointer; transition: all 160ms ease;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .toggle:hover { background: var(--sand); }
  .toggle.on { background: var(--near-black); color: var(--ivory); border-color: var(--near-black); }
  .toggle .swatch { width: 9px; height: 9px; border-radius: 2px; background: var(--paper-band); border: 1px solid var(--silver); }
  .toggle.on .swatch { background: var(--ivory); border-color: var(--ivory); opacity: 0.6; }

  .legend-row {
    display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
    margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border-cream);
  }
  .legend-item {
    display: flex; align-items: center; gap: 8px;
    padding: 4px 10px; border-radius: 16px; cursor: pointer;
    font-family: var(--sans); font-size: 12.5px; color: var(--charcoal);
    transition: background 150ms ease, opacity 150ms ease;
  }
  .legend-item:hover { background: var(--sand); }
  .legend-item.dim { opacity: 0.40; }
  .legend-swatch { width: 16px; height: 3px; border-radius: 2px; }
  .legend-val { font-family: var(--mono); font-size: 11.5px; color: var(--stone); }

  /* ===== STATUS STRIP ===== */
  .strip {
    max-width: 1240px; margin: 22px auto 0; padding: 0 40px;
    display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
  }
  .chip {
    font-family: var(--sans); font-size: 12px;
    background: var(--ivory); border: 1px solid var(--border-warm);
    color: var(--charcoal); border-radius: 999px;
    padding: 5px 12px;
    display: inline-flex; align-items: center; gap: 7px;
    cursor: help; position: relative;
    transition: background 150ms ease;
    font-variant-numeric: tabular-nums;
  }
  .chip:hover { background: var(--sand); }
  .chip.ok::before { content: '✓'; color: var(--olive); font-weight: 500; }
  .chip.warn {
    border-color: var(--terracotta); color: var(--terracotta);
    background: rgba(201,100,66,0.06);
    font-weight: 500;
  }
  .chip.warn::before { content: '⚠'; }
  .chip.warn:hover { background: rgba(201,100,66,0.12); }
  .chip.muted { color: var(--stone); border-color: var(--border-cream); }
  .chip.spacer { flex: 1; background: none; border: none; padding: 0; cursor: default; }

  .chip-pop {
    position: absolute; bottom: calc(100% + 8px); left: 0;
    background: var(--near-black); color: var(--silver);
    border-radius: 8px; padding: 8px 12px;
    font-size: 12px; line-height: 1.5; max-width: 280px;
    box-shadow: 0 8px 24px rgba(20,20,19,0.18);
    opacity: 0; pointer-events: none;
    transform: translateY(4px);
    transition: opacity 140ms ease, transform 140ms ease;
    white-space: normal; z-index: 30;
  }
  .chip:hover .chip-pop { opacity: 1; transform: translateY(0); }

  /* Discrepancy panel header — terracotta to keep deviations visually loud. */
  .panel .label.warn { color: var(--terracotta); }

  /* Provenance footer grid (4 columns: Run · Cluster · Source · Harness) */
  .panel.provenance-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 24px; padding: 22px 28px;
  }
  .prov-line { margin: 0; }
  .prov-code { font-family: var(--mono); font-size: 12px; color: var(--olive); }

  /* Additional figures (when N > 1). Featured fig lives in .hero. */
  .extra-figs {
    max-width: 1240px; margin: 56px auto 0; padding: 0 40px;
    display: flex; flex-direction: column; gap: 40px;
  }
  .extra-figs .fig-block { padding-top: 28px; border-top: 1px solid var(--border-cream); }
  .fig-eyebrow {
    font-family: var(--sans); font-size: 10px; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--olive);
    margin-bottom: 14px;
  }

  .scroll-hint {
    max-width: 1240px; margin: 32px auto 0; padding: 0 40px;
    text-align: center; font-family: var(--sans); font-size: 11px;
    color: var(--stone); letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.7;
  }
  .scroll-hint .dn { display: inline-block; margin: 4px 0; font-size: 18px; line-height: 1; color: var(--terracotta); animation: bob 1800ms ease-in-out infinite; }
  @keyframes bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(4px); } }

  .below {
    max-width: 1240px; margin: 56px auto 0; padding: 0 40px 80px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
  }
  .panel { background: var(--ivory); border: 1px solid var(--border-cream); border-radius: 16px;
    padding: 24px 28px; box-shadow: 0 0 0 1px var(--border-cream); }
  .panel.full { grid-column: 1 / -1; }
  .panel h3 { font-family: var(--serif); font-weight: 500; font-size: 20px; line-height: 1.25;
    color: var(--near-black); margin: 0 0 14px; letter-spacing: -0.005em; }
  .panel .label { font-family: var(--sans); font-size: 10px; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--terracotta); margin-bottom: 8px; }
  .panel p { font-family: var(--sans); font-size: 14px; line-height: 1.65;
    color: var(--charcoal); margin: 0 0 12px; }
  .panel p b { color: var(--near-black); font-weight: 500; }
  .ctr { display: grid; grid-template-columns: 110px 1fr; gap: 10px 20px; font-family: var(--sans); font-size: 13px; }
  .ctr .k { font-size: 10px; font-weight: 500; letter-spacing: 0.10em; text-transform: uppercase; color: var(--olive); padding-top: 4px; }
  .ctr .v { color: var(--charcoal); line-height: 1.55; }
  .ctr .v .pill { display: inline-block; font-family: var(--mono); font-size: 11px;
    background: var(--sand); border: 1px solid var(--ring-warm);
    border-radius: 4px; padding: 1px 7px; margin: 2px 4px 2px 0; color: var(--charcoal); }
  .ctr .v .claim-line-c { padding: 6px 0; border-bottom: 1px dashed var(--border-cream); display: flex; gap: 10px; align-items: baseline; }
  .ctr .v .claim-line-c:last-child { border-bottom: none; }
  .ctr .v .claim-line-c .id { font-family: var(--mono); font-size: 10.5px; color: var(--stone); flex-shrink: 0; width: 130px; }
  .ctr .v .claim-line-c .stmt { color: var(--near-black); font-family: var(--serif); font-size: 14px; line-height: 1.45; }

  .callout { position: absolute; pointer-events: none;
    background: var(--near-black); color: var(--silver);
    border-radius: 10px; padding: 12px 14px;
    font-family: var(--sans); font-size: 12px;
    box-shadow: 0 0 0 1px var(--near-black), 0 12px 32px rgba(20,20,19,0.18);
    opacity: 0; transition: opacity 140ms ease, transform 140ms ease;
    transform: translateY(4px); z-index: 50; min-width: 220px; }
  .callout.show { opacity: 1; transform: translateY(0); }
  .callout-row { display: flex; justify-content: space-between; gap: 14px; margin: 3px 0; }
  .callout-row span { color: var(--silver); }
  .callout-row b { color: #ffffff; font-family: var(--mono); font-weight: 400; font-variant-numeric: tabular-nums; }
  .callout-divider { height: 1px; background: rgba(255,255,255,0.10); margin: 8px 0; }
  .callout-meta { font-family: var(--mono); font-size: 11px; color: var(--silver); margin-top: 4px; }

  .glossbox { position: fixed; max-width: 320px;
    background: var(--ivory); border: 1px solid var(--border-warm);
    border-radius: 12px; padding: 14px 16px;
    box-shadow: 0 0 0 1px var(--ring-warm), 0 12px 32px rgba(20,20,19,0.06);
    font-family: var(--sans); font-size: 13.5px; line-height: 1.55; color: var(--charcoal);
    opacity: 0; transform: translateY(4px);
    transition: opacity 150ms ease, transform 150ms ease;
    pointer-events: none; z-index: 200; }
  .glossbox.show { opacity: 1; transform: translateY(0); }
  .glossbox .label { font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--terracotta); margin-bottom: 6px; }
  .glossbox .term-name { font-family: var(--serif); font-size: 17px; color: var(--near-black); margin-bottom: 6px; line-height: 1.25; }
  .glossbox .formula { font-family: var(--mono); font-size: 12.5px; color: var(--olive); margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border-cream); }

  .drawer { position: fixed; top: 0; right: 0; bottom: 0; width: 440px;
    background: var(--ivory); border-left: 1px solid var(--border-warm);
    box-shadow: -10px 0 32px rgba(20,20,19,0.08);
    transform: translateX(100%);
    transition: transform 280ms cubic-bezier(0.32, 0.72, 0, 1);
    z-index: 100; overflow-y: auto; padding: 28px 32px; }
  .drawer.open { transform: translateX(0); }
  .drawer-close { position: absolute; top: 18px; right: 22px; background: none; border: none; cursor: pointer; color: var(--stone); font-size: 22px; line-height: 1; }
  .drawer-close:hover { color: var(--near-black); }
  .drawer .label { font-family: var(--sans); font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terracotta); margin-bottom: 8px; }
  .drawer h3 { font-family: var(--serif); font-weight: 500; font-size: 22px; line-height: 1.20; color: var(--near-black); margin: 0 0 6px; }
  .drawer .sub { font-family: var(--mono); font-size: 11px; color: var(--stone); margin-bottom: 22px; word-break: break-all; }
  .drawer-section { margin-bottom: 22px; }
  .drawer-section .stitle { font-family: var(--sans); font-size: 11px; font-weight: 500; letter-spacing: 0.10em; text-transform: uppercase; color: var(--olive); margin-bottom: 10px; }
  .drawer-kv { display: flex; justify-content: space-between; padding: 8px 0; font-family: var(--sans); font-size: 13.5px; color: var(--charcoal); border-bottom: 1px solid var(--border-cream); }
  .drawer-kv b { font-family: var(--mono); font-weight: 400; color: var(--near-black); font-variant-numeric: tabular-nums; }
  .drawer-backdrop { position: fixed; inset: 0; background: rgba(20,20,19,0.18); opacity: 0; pointer-events: none; transition: opacity 280ms ease; z-index: 99; }
  .drawer-backdrop.show { opacity: 1; pointer-events: auto; }

  /* ===== Tap-fallback (any touch device) ===== */
  @media (hover: none) {
    .chip { cursor: pointer; }
    .chip-pop { display: none; }
    .chip.tapped .chip-pop { display: block; opacity: 1; transform: translateY(0); }
    .sym { cursor: pointer; }
  }
  /* On any device, .tapped chips show their popover (used as click toggle on mobile) */
  .chip.tapped .chip-pop { opacity: 1; transform: translateY(0); }

  /* ===== Tablet (640-991px) ===== */
  @media (max-width: 991px) {
    .topbar, .hero, .strip, .scroll-hint, .below { padding-left: 24px; padding-right: 24px; }
    .duo { gap: 14px; }
    .panel-card { padding: 20px 22px 16px; }
    svg.plot { height: 320px; }
    .drawer { width: 380px; }
    .below { grid-template-columns: 1fr; gap: 16px; }
    .panel.full { grid-template-columns: repeat(2, 1fr) !important; }
  }

  /* ===== Mobile (<640px) ===== */
  @media (max-width: 640px) {
    .topbar { grid-template-columns: 1fr; padding: 16px 18px; gap: 8px; }
    .topbar .meta { text-align: left; font-size: 10.5px; }
    .topbar .id { display: inline-block; margin-bottom: 4px; }

    .hero { padding: 24px 18px 20px; }
    .claim-line { flex-direction: column; align-items: flex-start; gap: 10px; margin-bottom: 18px; }
    .claim { font-size: 22px; line-height: 1.20; }
    .claim-tag { padding-top: 0; font-size: 10px; }

    /* Stack the side-by-side */
    .duo { grid-template-columns: 1fr; gap: 14px; }
    .panel-card { padding: 18px 20px 14px; border-radius: 18px; }
    .panel-title { font-size: 14px; margin-bottom: 10px; }
    .paper-img-wrap { padding: 12px 14px; min-height: 200px; }
    .plot-area { min-height: 280px; }
    svg.plot { height: 280px; }
    .ours-controls { position: static; margin-bottom: 10px; }
    .legend-row { gap: 6px; padding-top: 10px; }
    .legend-item { padding: 4px 8px; font-size: 12px; }

    .strip { padding: 0 18px; gap: 6px; margin-top: 14px; }
    .chip { font-size: 11.5px; padding: 6px 12px; min-height: 32px; }
    .chip.spacer { display: none; }
    /* Tap-driven popover on mobile, repositioned to avoid overflow */
    .chip-pop { left: 0; right: 0; bottom: auto; top: calc(100% + 6px); max-width: none; }

    .scroll-hint { margin-top: 24px; padding: 0 18px; font-size: 10px; }

    .below { padding: 0 18px 56px; margin-top: 40px; gap: 14px; }
    .panel { padding: 18px 20px; border-radius: 14px; }
    .panel h3 { font-size: 18px; }
    .panel.full { grid-template-columns: 1fr !important; gap: 14px; padding: 18px 20px !important; }
    .ctr { grid-template-columns: 90px 1fr; gap: 8px 14px; font-size: 12.5px; }

    /* Drawer becomes a bottom sheet */
    .drawer {
      top: auto; bottom: 0; left: 0; right: 0; width: 100%;
      max-height: 80vh; border-left: none; border-top: 1px solid var(--border-warm);
      border-radius: 18px 18px 0 0;
      transform: translateY(100%);
    }
    .drawer.open { transform: translateY(0); }
    .drawer-close { top: 14px; right: 18px; font-size: 26px; padding: 4px 10px; }

    /* Callout repositioned for mobile (closer to top, away from sticky finger) */
    .callout { font-size: 11px; min-width: 200px; }
  }

  /* ===== Touch-friendly point hit area ===== */
  svg.plot .pt { stroke: transparent; stroke-width: 14; paint-order: stroke; }

  /* Per-cell verdict rings: drawn as a separate <circle class="pt-ring"> behind
     the .pt. Only rendered when the data row carries a `verdict` field.
     match → no ring; proxy → coral hairline; fail → terracotta solid ring. */
  svg.plot .pt-ring { fill: none; pointer-events: none; transition: opacity 220ms ease, r 140ms ease; }
  svg.plot .pt-ring.proxy { stroke: var(--coral); stroke-width: 1.5; opacity: 0.65; }
  svg.plot .pt-ring.fail  { stroke: var(--terracotta); stroke-width: 2.0; opacity: 0.85; }
  svg.plot .pt-ring.dim { opacity: 0.10; }
</style>
</head>
<body>

<div class="topbar">
  <div class="paper">__TOPBAR_PAPER_HTML__</div>
  <div class="meta">
    __RUN_SCOPE__<br>
    __RUN_META__
  </div>
</div>

<section class="hero">
  <div class="claim-line">
    <h1 class="claim">__HEADLINE_HTML__</h1>
    <span class="claim-tag">__RUN_TAG__</span>
  </div>

  __VERDICT_HTML__

  __FEATURED_FIG_HTML__

  <div class="strip">
    __STATUS_STRIP_HTML__
  </div>
</section>

__EXTRA_FIGS_SECTION__

<div class="scroll-hint">
  <span class="dn">↓</span><br>
  Contract · Discrepancy · Provenance
</div>

<div class="below">
  <div class="panel">
    <div class="label">Contract</div>
    <h3>Reproduction obligations and accepted deviations.</h3>
    <div class="ctr">__CONTRACT_HTML__</div>
  </div>

  <div class="panel" id="discrepancy-panel">
    <div class="label warn">⚠ Discrepancy</div>
    <h3>__DISCREPANCY_HEADLINE__</h3>
    __DISCREPANCY_HTML__
  </div>

  <div class="panel full provenance-grid">
    __PROVENANCE_HTML__
  </div>
</div>

<div class="glossbox" id="glossbox">
  <div class="label">Term</div>
  <div class="term-name" id="gb-name"></div>
  <div id="gb-body"></div>
  <div class="formula" id="gb-formula"></div>
</div>

<div class="drawer-backdrop" id="backdrop" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <button class="drawer-close" onclick="closeDrawer()">×</button>
  <div class="label">Cell manifest</div>
  <h3 id="drawer-title">Cell</h3>
  <div class="sub" id="drawer-sub">—</div>
  <div class="drawer-section">
    <div class="stitle">Result</div>
    <div id="drawer-result-rows"></div>
  </div>
  <div class="drawer-section">
    <div class="stitle">Cell payload</div>
    <div id="drawer-payload-rows"></div>
  </div>
</div>

<script>
  const GLOSS = __GLOSS_JSON__;
  const gb = document.getElementById('glossbox');
  document.querySelectorAll('.sym').forEach(t => {
    t.addEventListener('mouseenter', () => {
      const def = GLOSS[t.dataset.term]; if (!def) return;
      document.getElementById('gb-name').textContent = def.name;
      document.getElementById('gb-body').textContent = def.body;
      const f = document.getElementById('gb-formula');
      f.textContent = def.formula; f.style.display = def.formula ? 'block' : 'none';
      const r = t.getBoundingClientRect();
      gb.style.left = Math.min(r.left, window.innerWidth - 340) + 'px';
      gb.style.top = (r.bottom + 8) + 'px';
      gb.classList.add('show');
    });
    t.addEventListener('mouseleave', () => gb.classList.remove('show'));
  });

  // Generic plot driver — consumes (axes, data) schema from figs/<id>.json.
  // Multi-figure: each figure runs the driver in its own closure, scoped to
  //   IDs `plot-<label>`, `callout-<label>`, `legend-<label>`, `toggle-window-<label>`.
  // Required: axes.x.field, axes.y.field, data:[{...}].
  // Optional: axes.curves.field, axes.err.field, axes.x.refline:{value,label},
  //           axes.y.paper_window:{lo,hi}, axes.{x,y}.scale = "linear"|"log".
  const FIGURES = __FIGURES_JSON__;
  const colors = __COLORS_JSON__;
  const RUN_ID = "__RUN_ID__";

  function escapeXml(s) {
    return String(s).replace(/[<>&"']/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c]));
  }
  // Greek letters (subset) for inline markup. Mirrors render_inline_markup in render.py.
  const GREEK_PAIRS = [
    ['alpha','α'],['beta','β'],['gamma','γ'],['delta','δ'],['epsilon','ε'],
    ['zeta','ζ'],['eta','η'],['theta','θ'],['iota','ι'],['kappa','κ'],
    ['lambda','λ'],['mu','μ'],['nu','ν'],['xi','ξ'],['pi','π'],['rho','ρ'],
    ['sigma','σ'],['tau','τ'],['phi','φ'],['chi','χ'],['psi','ψ'],['omega','ω'],
    ['Alpha','Α'],['Beta','Β'],['Gamma','Γ'],['Delta','Δ'],['Sigma','Σ'],
    ['Lambda','Λ'],['Omega','Ω'],['Pi','Π'],
  ];
  // Convert ASCII LaTeX-style markup (_X / _{XX} / ^X / ^{XX} / Greek words /
  // operators) to inline SVG-safe markup with <tspan> for sub/superscripts.
  // Use inside SVG <text>; for HTML body content, use Python's render_inline_markup.
  function markupToSvg(text) {
    if (text == null) return '';
    let t = String(text);
    // Operator transforms BEFORE escape (raw `<=` → `≤`, then we escape stray `<`).
    t = t.replace(/<=/g, '≤').replace(/>=/g, '≥').replace(/!=/g, '≠')
         .replace(/ \+\/- /g, ' ± ').replace(/\+\/-/g, '±')
         .replace(/\\approx/g, '≈').replace(/~=/g, '≈');
    GREEK_PAIRS.forEach(([w, ch]) => { t = t.replace(new RegExp(`\\b${w}\\b`, 'g'), ch); });
    // Escape any remaining XML-meaningful chars.
    t = t.replace(/[<>&"']/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c]));
    // Subscripts: _{XX} unambiguous; _X requires X NOT followed by another alnum
    // so `tfim_fig` stays whole but `c_L(h)` matches.
    t = t.replace(/_\{([^}]+)\}/g, '<tspan baseline-shift="sub" font-size="0.75em">$1</tspan>');
    t = t.replace(/_([A-Za-z0-9])(?![A-Za-z0-9])/g, '<tspan baseline-shift="sub" font-size="0.75em">$1</tspan>');
    t = t.replace(/\^\{([^}]+)\}/g, '<tspan baseline-shift="super" font-size="0.75em">$1</tspan>');
    t = t.replace(/\^([A-Za-z0-9])(?![A-Za-z0-9])/g, '<tspan baseline-shift="super" font-size="0.75em">$1</tspan>');
    return t;
  }
  function prettyKey(k) {
    return k.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  }
  function fmtVal(v) {
    if (v == null) return '—';
    if (typeof v === 'number') {
      if (Number.isInteger(v)) return v.toLocaleString();
      return Math.abs(v) < 1e-3 || Math.abs(v) >= 1e6 ? v.toExponential(3) : v.toFixed(4);
    }
    return String(v);
  }
  // "Nice" linear tick step targeting ~5 ticks
  function niceStep(range, target) {
    const rough = range / target;
    const mag = Math.pow(10, Math.floor(Math.log10(rough)));
    const norm = rough / mag;
    const s = norm < 1.5 ? 1 : norm < 3.5 ? 2 : norm < 7.5 ? 5 : 10;
    return s * mag;
  }
  function linearTicks(lo, hi, target) {
    const step = niceStep(hi - lo, target);
    const start = Math.ceil(lo / step) * step;
    const out = [];
    for (let v = start; v <= hi + step * 1e-9; v += step) out.push(v);
    return { ticks: out, step };
  }
  function logTicks(lo, hi) {
    // Emit 1, 2, 5 multiples per decade in range so short log spans still get ~3-5 ticks.
    const out = [];
    const e0 = Math.floor(Math.log10(lo));
    const e1 = Math.ceil(Math.log10(hi));
    for (let e = e0; e <= e1; e++) {
      const base = Math.pow(10, e);
      [1, 2, 5].forEach(m => {
        const v = m * base;
        if (v >= lo * 0.99 && v <= hi * 1.01) out.push(v);
      });
    }
    return { ticks: out, step: null };
  }
  function fmtTick(v, step, scale) {
    if (scale === 'log') {
      const e = Math.log10(v);
      if (Math.abs(e - Math.round(e)) < 1e-9) {
        const k = Math.round(e);
        return k === 0 ? '1' : (k === 1 ? '10' : `10^${k}`);
      }
      return v < 100 ? String(v) : v.toExponential(0);
    }
    const dp = step >= 1 ? 0 : Math.max(0, -Math.floor(Math.log10(step)));
    return v.toFixed(dp);
  }

  // Drawer is page-shared (one cell view at a time).
  const drawer = document.getElementById('drawer');
  const backdrop = document.getElementById('backdrop');
  function closeDrawer() { drawer.classList.remove('open'); backdrop.classList.remove('show'); }
  window.closeDrawer = closeDrawer;
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrawer(); });

  function openDrawerForRow(fig, row) {
    const xField = fig.axes.x.field, yField = fig.axes.y.field;
    const curveField = (fig.axes.curves || {}).field || null;
    const errField = (fig.axes.err || {}).field || null;
    const titleParts = [];
    if (curveField) titleParts.push(`${curveField} = ${row[curveField]}`);
    titleParts.push(`${xField} = ${fmtVal(row[xField])}`);
    document.getElementById('drawer-title').textContent = titleParts.join(', ');
    document.getElementById('drawer-sub').textContent = row.manifest
      ? `results/${RUN_ID}/cells/${row.manifest}` : `results/${RUN_ID}/ · ${fig.label}`;

    const yv = row[yField], ev = errField ? (row[errField] || 0) : 0;
    let resultHtml = `<div class="drawer-kv"><span>${escapeXml(yField)}</span><b>${fmtVal(yv)}</b></div>`;
    if (errField) {
      resultHtml += `<div class="drawer-kv"><span>± 1σ</span><b>${fmtVal(ev)}</b></div>`;
      resultHtml += `<div class="drawer-kv"><span>95% CI</span><b>± ${fmtVal(1.96 * ev)}</b></div>`;
    }
    document.getElementById('drawer-result-rows').innerHTML = resultHtml;

    const reserved = new Set([xField, yField, curveField, errField, 'manifest']);
    let payloadHtml = '';
    Object.keys(row).forEach(k => {
      if (reserved.has(k)) return;
      payloadHtml += `<div class="drawer-kv"><span>${escapeXml(prettyKey(k))}</span><b>${escapeXml(fmtVal(row[k]))}</b></div>`;
    });
    document.getElementById('drawer-payload-rows').innerHTML = payloadHtml
      || '<div class="drawer-kv" style="color: var(--stone)">No additional fields recorded.</div>';

    drawer.classList.add('open');
    backdrop.classList.add('show');
  }

  function initFig(fig) {
    const label = fig.label;
    const plotEl = document.getElementById(`plot-${label}`);
    const calloutEl = document.getElementById(`callout-${label}`);
    const legendEl = document.getElementById(`legend-${label}`);
    const toggleEl = document.getElementById(`toggle-window-${label}`);
    if (!plotEl) return;

    const xField = fig.axes.x.field;
    const yField = fig.axes.y.field;
    const curveField = (fig.axes.curves || {}).field || null;
    const errField = (fig.axes.err || {}).field || null;
    const xLabel = fig.axes.x.label || xField;
    const yLabel = fig.axes.y.label || yField;
    const xScale = fig.axes.x.scale || 'linear';
    const yScale = fig.axes.y.scale || 'linear';
    const xRefline = fig.axes.x.refline || null;
    const paperWindow = (fig.axes.y || {}).paper_window || null;

    const curveKeys = curveField
      ? [...new Set(fig.data.map(d => d[curveField]))]
          .sort((a,b) => (typeof a === 'number') ? a-b : String(a).localeCompare(String(b)))
      : [null];
    const rowsOf = key => (key === null ? fig.data : fig.data.filter(d => d[curveField] === key))
      .slice().sort((a, b) => a[xField] - b[xField]);

    // Auto-derive ranges with padding (strip non-positive values for log).
    const validX = fig.data.map(d => d[xField]).filter(v => xScale !== 'log' || v > 0);
    const yPieces = fig.data.flatMap(d => {
      const y = d[yField], e = errField ? (d[errField] || 0) : 0;
      const lo = y - e, hi = y + e;
      return yScale === 'log' ? [lo, hi].filter(v => v > 0) : [lo, hi];
    });
    const dataXmin = Math.min(...validX), dataXmax = Math.max(...validX);
    const dataYmin = Math.min(...yPieces), dataYmax = Math.max(...yPieces);
    let fullX, fullY;
    if (xScale === 'log') fullX = [dataXmin / 1.2, dataXmax * 1.2];
    else { const p = (dataXmax - dataXmin) * 0.05 || 0.1; fullX = [dataXmin - p, dataXmax + p]; }
    if (yScale === 'log') fullY = [dataYmin / 1.4, dataYmax * 1.4];
    else { const p = (dataYmax - dataYmin) * 0.08 || 0.1; fullY = [dataYmin - p, dataYmax + p]; }

    const W=600, H=360, M={l:54, r:14, t:18, b:42};
    let xMin = fullX[0], xMax = fullX[1];
    let yMin = fullY[0], yMax = fullY[1];

    function xs(v) {
      if (xScale === 'log') {
        return M.l + (Math.log10(v) - Math.log10(xMin)) / (Math.log10(xMax) - Math.log10(xMin)) * (W - M.l - M.r);
      }
      return M.l + (v - xMin) / (xMax - xMin) * (W - M.l - M.r);
    }
    function ys(v) {
      if (yScale === 'log') {
        return H - M.b - (Math.log10(v) - Math.log10(yMin)) / (Math.log10(yMax) - Math.log10(yMin)) * (H - M.t - M.b);
      }
      return H - M.b - (v - yMin) / (yMax - yMin) * (H - M.t - M.b);
    }
    function tickGen(scale, lo, hi) {
      return scale === 'log' ? logTicks(lo, hi) : linearTicks(lo, hi, 5);
    }

    function focusKey(key) {
      plotEl.querySelectorAll('.curve, .pt, .errbar, .pt-ring').forEach(el => el.classList.remove('focus','dim'));
      legendEl.querySelectorAll('.legend-item').forEach(el => el.classList.remove('focus','dim'));
      if (key === null) return;
      plotEl.querySelectorAll('[data-l]').forEach(el => {
        if (el.dataset.l === key) el.classList.add('focus'); else el.classList.add('dim');
      });
      legendEl.querySelectorAll('[data-l]').forEach(el => {
        if (el.dataset.l === key) el.classList.add('focus'); else el.classList.add('dim');
      });
    }

    function renderPlot() {
      let g = '';
      if (paperWindow && yScale !== 'log') {
        g += `<rect class="paper-window" data-pw="1" x="${M.l}" y="${ys(paperWindow.hi)}" width="${W-M.l-M.r}" height="${ys(paperWindow.lo)-ys(paperWindow.hi)}"/>`;
        g += `<text class="paper-window-label" data-pwl="1" x="${W-M.r-6}" y="${ys((paperWindow.lo+paperWindow.hi)/2)+4}" text-anchor="end">paper y-window</text>`;
      }
      const xT = tickGen(xScale, xMin, xMax);
      xT.ticks.forEach(v => {
        g += `<line class="grid" x1="${xs(v)}" x2="${xs(v)}" y1="${M.t}" y2="${H-M.b}"/>`;
        g += `<text class="tick" x="${xs(v)}" y="${H-M.b+16}" text-anchor="middle">${fmtTick(v, xT.step, xScale)}</text>`;
      });
      const yT = tickGen(yScale, yMin, yMax);
      yT.ticks.forEach(v => {
        g += `<line class="grid" x1="${M.l}" x2="${W-M.r}" y1="${ys(v)}" y2="${ys(v)}"/>`;
        g += `<text class="tick" x="${M.l-8}" y="${ys(v)+4}" text-anchor="end">${fmtTick(v, yT.step, yScale)}</text>`;
      });
      if (yScale !== 'log' && yMin <= 0 && yMax >= 0) {
        g += `<line class="zero" x1="${M.l}" x2="${W-M.r}" y1="${ys(0)}" y2="${ys(0)}"/>`;
      }
      if (xRefline && xRefline.value >= xMin && xRefline.value <= xMax) {
        g += `<line class="hcline" x1="${xs(xRefline.value)}" x2="${xs(xRefline.value)}" y1="${M.t}" y2="${H-M.b}"/>`;
        g += `<text class="hclabel" x="${xs(xRefline.value)+5}" y="${M.t+12}">${markupToSvg(xRefline.label || '')}</text>`;
      }
      g += `<line class="axis" x1="${M.l}" x2="${W-M.r}" y1="${H-M.b}" y2="${H-M.b}"/>`;
      g += `<line class="axis" x1="${M.l}" x2="${M.l}" y1="${M.t}" y2="${H-M.b}"/>`;
      g += `<text class="axis-label" x="${(W+M.l-M.r)/2}" y="${H-8}" text-anchor="middle">${markupToSvg(xLabel)}</text>`;
      g += `<text class="axis-label" transform="rotate(-90 16 ${(H+M.t-M.b)/2})" x="16" y="${(H+M.t-M.b)/2}" text-anchor="middle">${markupToSvg(yLabel)}</text>`;

      curveKeys.forEach((key, i) => {
        const color = colors[i % colors.length];
        const pts = rowsOf(key);
        const dataKey = key === null ? '_' : String(key);
        const path = pts
          .filter(p => (xScale !== 'log' || p[xField] > 0) && (yScale !== 'log' || p[yField] > 0))
          .map((p,k) => `${k===0?'M':'L'} ${xs(p[xField]).toFixed(2)} ${ys(p[yField]).toFixed(2)}`).join(' ');
        g += `<path class="curve draw" data-l="${escapeXml(dataKey)}" stroke="${color}" d="${path}" style="animation-delay: ${i*150}ms"/>`;
        pts.forEach((p,k) => {
          const yv = p[yField];
          if (xScale === 'log' && p[xField] <= 0) return;
          if (yScale === 'log' && yv <= 0) return;
          const ev = errField ? (p[errField] || 0) : 0;
          if (errField) {
            const yLo = yScale === 'log' ? Math.max(yv - ev, yMin) : (yv - ev);
            const yHi = yv + ev;
            if (yLo > 0 || yScale !== 'log') {
              g += `<line class="errbar" data-l="${escapeXml(dataKey)}" stroke="${color}" x1="${xs(p[xField])}" x2="${xs(p[xField])}" y1="${ys(yHi)}" y2="${ys(yLo)}"/>`;
            }
          }
          const inView = (yv >= yMin && yv <= yMax);
          // Per-cell verdict ring (only if row carries `verdict` and it's not "match").
          const verdict = p.verdict;
          if (verdict && verdict !== 'match' && inView) {
            g += `<circle class="pt-ring ${escapeXml(verdict)}" data-l="${escapeXml(dataKey)}" cx="${xs(p[xField])}" cy="${ys(yv)}" r="7.5"/>`;
          }
          g += `<circle class="pt" data-l="${escapeXml(dataKey)}" data-k="${k}" cx="${xs(p[xField])}" cy="${ys(yv)}" r="${inView ? 3.6 : 2.2}" fill="${color}" opacity="${inView ? 1 : 0.45}"/>`;
        });
      });
      plotEl.innerHTML = g;
      bindPoints();
      if (paperWindow && toggleEl && toggleEl.classList.contains('on')) {
        plotEl.querySelectorAll('[data-pw]').forEach(el => el.classList.add('on'));
        plotEl.querySelectorAll('[data-pwl]').forEach(el => el.classList.add('on'));
      }
    }

    function bindPoints() {
      plotEl.querySelectorAll('.pt').forEach(pt => {
        pt.addEventListener('mouseenter', () => {
          const key = pt.dataset.l, k = +pt.dataset.k;
          const row = rowsOf(key === '_' ? null : (typeof curveKeys[0] === 'number' ? +key : key))[k];
          focusKey(key);
          pt.setAttribute('r', '6');
          const headLeft = curveField ? `${curveField} · ${xField}` : xField;
          const headRight = curveField ? `${row[curveField]} · ${fmtVal(row[xField])}` : fmtVal(row[xField]);
          let html = `<div class="callout-row"><span>${escapeXml(headLeft)}</span><b>${escapeXml(headRight)}</b></div>`;
          if (row.verdict) {
            const vColor = row.verdict === 'match' ? '#a3a39c' : (row.verdict === 'proxy' ? '#d97757' : '#c96442');
            const vIcon  = row.verdict === 'match' ? '✓' : (row.verdict === 'proxy' ? '◐' : '✗');
            html += `<div class="callout-row"><span>vs paper</span><b style="color:${vColor}">${vIcon} ${escapeXml(row.verdict)}</b></div>`;
          }
          html += `<div class="callout-divider"></div>`;
          html += `<div class="callout-row"><span>${escapeXml(yField)}</span><b>${fmtVal(row[yField])}</b></div>`;
          if (errField) html += `<div class="callout-row"><span>± 1σ</span><b>${fmtVal(row[errField])}</b></div>`;
          if (row.accept != null || row.wall != null) {
            html += `<div class="callout-divider"></div>`;
            if (row.accept != null) html += `<div class="callout-row"><span>accept</span><b>${(row.accept*100).toFixed(1)}%</b></div>`;
            if (row.wall != null) html += `<div class="callout-row"><span>wall</span><b>${(row.wall/60).toFixed(1)} min</b></div>`;
          }
          if (row.when) html += `<div class="callout-meta">${escapeXml(row.when)}</div>`;
          if (row.manifest) html += `<div class="callout-meta">${escapeXml(row.manifest)}</div>`;
          calloutEl.innerHTML = html;
          const r = pt.getBoundingClientRect();
          const wrap = pt.closest('.plot-area').getBoundingClientRect();
          const left = Math.min(r.left - wrap.left + 14, wrap.width - 250);
          calloutEl.style.left = Math.max(0, left) + 'px';
          calloutEl.style.top = (r.top - wrap.top - 8) + 'px';
          calloutEl.classList.add('show');
        });
        pt.addEventListener('mouseleave', () => {
          const key = pt.dataset.l, k = +pt.dataset.k;
          const row = rowsOf(key === '_' ? null : (typeof curveKeys[0] === 'number' ? +key : key))[k];
          const inView = (row[yField] >= yMin && row[yField] <= yMax);
          pt.setAttribute('r', inView ? '3.6' : '2.2');
          calloutEl.classList.remove('show');
          focusKey(null);
        });
        pt.addEventListener('click', () => {
          const key = pt.dataset.l, k = +pt.dataset.k;
          const row = rowsOf(key === '_' ? null : (typeof curveKeys[0] === 'number' ? +key : key))[k];
          openDrawerForRow(fig, row);
        });
      });
    }

    // Legend
    if (curveField) {
      const labelTpl = (fig.axes.curves || {}).label_template || `${curveField} = {${curveField}}`;
      curveKeys.forEach((key, i) => {
        const pts = rowsOf(key);
        const refV = xRefline ? pts.find(p => Math.abs(p[xField] - xRefline.value) < 1e-6) : null;
        const v = (refV || pts[pts.length-1] || {})[yField];
        const item = document.createElement('div');
        item.className = 'legend-item'; item.dataset.l = String(key);
        const labelText = labelTpl.replace(`{${curveField}}`, key);
        // Legend label uses the same SVG-style markup so chi/sub/sup render right.
        // Inserting via innerHTML is safe — markupToSvg escapes XML before tspans.
        // For HTML context we'd want <sub>/<sup> but <tspan> degrades to plain text in HTML,
        // so swap the SVG tspans for HTML sub/sup here.
        const labelHtml = markupToSvg(labelText)
          .replace(/<tspan baseline-shift="sub" font-size="0.75em">([^<]*)<\/tspan>/g, '<sub>$1</sub>')
          .replace(/<tspan baseline-shift="super" font-size="0.75em">([^<]*)<\/tspan>/g, '<sup>$1</sup>');
        item.innerHTML = `<span class="legend-swatch" style="background:${colors[i % colors.length]};"></span>
          ${labelHtml} <span class="legend-val">${(v != null) ? v.toFixed(2) : ''}</span>`;
        item.addEventListener('mouseenter', () => focusKey(String(key)));
        item.addEventListener('mouseleave', () => focusKey(null));
        legendEl.appendChild(item);
      });
    }

    // Paper-window toggle (only when defined and y-axis is linear).
    if (paperWindow && yScale !== 'log' && toggleEl) {
      toggleEl.style.display = '';
      toggleEl.addEventListener('click', () => {
        const on = toggleEl.classList.toggle('on');
        if (on) { yMin = paperWindow.lo; yMax = paperWindow.hi; }
        else    { yMin = fullY[0]; yMax = fullY[1]; }
        renderPlot();
      });
    }

    renderPlot();
  }

  FIGURES.forEach(initFig);

  // ===== Tap-fallback for hover affordances (chips + glossary terms) =====
  // Detect touch capability; toggle .tapped class on click; tap-outside to dismiss
  const isTouch = matchMedia('(hover: none)').matches;
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', e => {
      e.stopPropagation();
      const wasTapped = chip.classList.contains('tapped');
      document.querySelectorAll('.chip.tapped').forEach(c => c.classList.remove('tapped'));
      if (!wasTapped) chip.classList.add('tapped');
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.chip.tapped').forEach(c => c.classList.remove('tapped'));
  });

  // Glossary term: tap toggles glossbox on touch devices (in addition to hover)
  document.querySelectorAll('.sym').forEach(t => {
    t.addEventListener('click', e => {
      e.stopPropagation();
      const def = GLOSS[t.dataset.term]; if (!def) return;
      const showing = gb.classList.contains('show');
      if (showing) { gb.classList.remove('show'); return; }
      document.getElementById('gb-name').textContent = def.name;
      document.getElementById('gb-body').textContent = def.body;
      const f = document.getElementById('gb-formula');
      f.textContent = def.formula; f.style.display = def.formula ? 'block' : 'none';
      const r = t.getBoundingClientRect();
      gb.style.left = Math.min(r.left, window.innerWidth - 340) + 'px';
      gb.style.top = (r.bottom + 8) + 'px';
      gb.classList.add('show');
    });
  });
  // Tap outside dismisses glossbox on touch
  if (isTouch) {
    document.addEventListener('click', e => {
      if (!e.target.closest('.sym') && !e.target.closest('.glossbox')) {
        gb.classList.remove('show');
      }
    });
  }
</script>
</body>
</html>
